# PostgreSQL (Neon مجاني — مطلوب للاستضافة على Render)
# مثال: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# رابط الموقع بعد الرفع (بدون / في النهاية)
NEXT_PUBLIC_APP_URL="https://your-app.onrender.com"

NEXT_PUBLIC_GA4_MEASUREMENT_ID=""
IP_HASH_SALT="change-me-to-a-long-random-string"

# حساب المدير (يُنشأ عبر npm run db:seed عند أول build)
MANAGER_EMAIL="admin@company.com"
MANAGER_PASSWORD="admin123"
